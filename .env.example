# Required — free at newsapi.org/register
NEWSAPI_KEY=your_key_here

# Required in production — set in Railway dashboard, not committed to git
MCP_AUTH_TOKEN=generate_a_strong_random_string

# Optional: RAGAS-inspired evaluation tool (set ENABLE_EVAL=true to activate)
ANTHROPIC_API_KEY=
ENABLE_EVAL=false

# Optional: UN Comtrade trade flow data (free key at comtradeapi.un.org)
COMTRADE_API_KEY=

# Optional: ITA Consolidated Screening List (free key at developer.trade.gov)
ITA_API_KEY=

# Optional overrides (Railway sets these via volume mount paths)
WHITEPAPER_DIR=
DB_PATH=
PORT=8000
